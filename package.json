{
  "name": "termdock",
  "version": "1.0.0",
  "description": "A complete web-based terminal application with modern UI",
  "type": "module",
  "bin": {
    "termdock": "dist/server/cli.js",
    "td": "dist/server/cli.js"
  },
  "exports": {
    ".": "./dist/server/entry.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "PORT=9835 tsx watch src/server/entry.ts",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json && chmod +x dist/server/cli.js",
    "generate:pwa-assets": "pwa-assets-generator --config pwa-assets.config.ts",
    "preview": "vite preview",
    "start": "node dist/server/cli.js",
    "lint": "tsc --noEmit",
    "test": "vitest --passWithNoTests",
    "test:ui": "vitest --ui",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@parcel/watcher": "^2.5.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/csurf": "^1.11.5",
    "@types/refractor": "^2.8.0",
    "@use-gesture/react": "^10.3.1",
    "@xterm/addon-clipboard": "^0.3.0-beta.287",
    "@xterm/addon-fit": "^0.12.0-beta.287",
    "@xterm/addon-image": "^0.10.0-beta.287",
    "@xterm/addon-ligatures": "^0.11.0-beta.287",
    "@xterm/addon-progress": "^0.3.0-beta.287",
    "@xterm/addon-search": "^0.17.0-beta.287",
    "@xterm/addon-serialize": "^0.15.0-beta.287",
    "@xterm/addon-unicode11": "^0.10.0-beta.287",
    "@xterm/addon-web-links": "^0.13.0-beta.287",
    "@xterm/addon-webgl": "^0.20.0-beta.286",
    "@xterm/xterm": "^6.1.0-beta.287",
    "browser-haptic": "^1.0.13",
    "cookie-parser": "^1.4.7",
    "dompurify": "^3.4.11",
    "express": "^5.2.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.16.0",
    "motion": "^12.40.0",
    "multicast-dns": "^7.2.5",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-diff-view": "^3.3.3",
    "react-dom": "^18.2.0",
    "refractor": "^2.10.1",
    "swiper": "^12.1.3",
    "tailwind-merge": "^2.2.0",
    "uuid": "^13.0.0",
    "ws": "^8.21.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "eslint": "^9.39.2",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "terminal",
    "termdock",
    "xterm",
    "express",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jovines/termdock.git"
  },
  "homepage": "https://github.com/Jovines/termdock#readme",
  "bugs": {
    "url": "https://github.com/Jovines/termdock/issues"
  }
}
