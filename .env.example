# Server Configuration
PORT=3001
NODE_ENV=development

# Terminal Configuration
TERM=xterm-256color
COLORTERM=truecolor

# Shell Configuration (default shell if not specified)
SHELL=/bin/zsh

# Maximum terminal sessions
MAX_TERMINAL_SESSIONS=20

# Idle timeout in milliseconds (30 minutes)
TERMINAL_IDLE_TIMEOUT=1800000

# 允许访问的主机列表（逗号分隔），用于后端 Host 校验及 Vite dev 服务器
# TERMDOCK_ALLOWED_HOSTS=yourdomain.com,192.168.x.x
