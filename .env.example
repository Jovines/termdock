# ====== Termdock 环境变量 ======
# 配置加载顺序（后者覆盖前者）：
#   1. 系统环境变量
#   2. ~/.termdock/.env（用户级，npm install -g 后推荐放这里）
#   3. CWD .env（项目级，用于开发）

# ---- 服务配置 ----

# 服务端口 (默认 9834)
# PORT=9834

# 监听地址 (默认 0.0.0.0)
# HOST=0.0.0.0

# ---- 终端行为配置 ----

# 终端空闲超时毫秒 (开发默认 30min, 生产默认 6h)
# TERMINAL_IDLE_TIMEOUT=21600000

# 重连时传回的滚动缓冲区行数 (默认 200)
# TERMINAL_RECONNECT_SCROLLBACK=200

# 流控暂停租赁时长毫秒 (默认 15000)
# TERMINAL_FLOW_CONTROL_PAUSE_LEASE_MS=15000

# 活跃程序检测轮询间隔毫秒 (默认 1200)
# TERMINAL_ACTIVE_PROGRAM_POLL_INTERVAL=1200

# ---- tmux 配置 ----

# tmux history-limit (默认 10000)
# TERMDOCK_TMUX_HISTORY_LIMIT=50000

# tmux 状态轮询间隔毫秒 (默认 500)
# TMUX_POLL_INTERVAL=500

# ---- 开发端口（一般不需要改） ----

# 前端开发服务器 Vite 端口 (默认 9833)
# TERMDOCK_PORT_FRONTEND=9833

# 后端开发 API 端口 (默认 9835)
# TERMDOCK_PORT_DEV_BACKEND=9835

# ---- Local Access 配置 ----

# mDNS 域名后缀 (默认 termdock.local)
# TERMDOCK_LOCAL_ACCESS_DOMAIN_SUFFIX=termdock.local

# mDNS 自动生成名称长度 (默认 4)
# TERMDOCK_LOCAL_ACCESS_NAME_LENGTH=4

# mDNS TTL 秒数 (默认 120)
# TERMDOCK_LOCAL_ACCESS_MDNS_TTL=120

# ---- 安全配置 ----

# 公网/反向代理域名白名单（逗号分隔）
# TERMDOCK_ALLOWED_HOSTS=yourdomain.com,192.168.x.x

# 允许终端访问的额外路径（路径分隔符分隔）
# ALLOWED_PATHS=/mnt/data:/home/other

# ---- 其他 ----

# Shell 路径 (默认从当前环境继承)
# SHELL=/bin/zsh

# NODE_ENV (默认 development)
# NODE_ENV=development

# TERM 类型 (默认 xterm-256color)
# TERM=xterm-256color

# 最大终端会话数 (默认 20)
# MAX_TERMINAL_SESSIONS=20
